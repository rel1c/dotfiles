#Alias for this file!
alias basha='vim ~/.bash_aliases'
alias bashs='source ~/.bashrc'

#Listing
alias l='ls --color'
alias la='ls -a --color'
alias ll='ls -alh --color'

#File navigation
alias cd..='cd ..'

#Some useful one letter aliases
alias q='exit'

#Personal log file
alias log='vim ~/Documents/logs/log.txt'
